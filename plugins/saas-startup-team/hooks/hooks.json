{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/enforce-handoff-naming.sh",
            "description": "Block non-conforming handoff filenames (NNN-<direction>.md only)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-regression-test.sh",
            "description": "Block `gh pr merge` for an incident-linked PR unless the diff adds a regression test (or an explicit override is recorded)"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-idle.sh",
            "description": "Validate founder wrote a handoff for current iteration before going idle"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-task-complete.sh",
            "description": "Validate task has deliverables for current iteration before marking complete"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/auto-learn.sh",
            "description": "Auto-extract project learnings from handoff/review/signoff files into CLAUDE.md"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-json.sh",
            "description": "Validate JSON syntax after editing .json files"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/enforce-delegation.sh",
            "description": "Prevent team lead from directly editing implementation code"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/auto-commit.sh",
            "description": "Auto-commit all work when a handoff file is written"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-handoff-secrets.sh",
            "description": "Auto-redact hardcoded secrets, API keys, and passwords from handoff files (never blocks the write — handoffs are gitignored, so blocking lost them silently)"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/enforce-tone.sh",
            "description": "Flag MVP/prototype language in handoff files"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-duplicate-handoff.sh",
            "description": "Warn when writing a handoff that duplicates existing work"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-growth-brief.sh",
            "description": "Ensure growth briefs have Objective and Target Customer sections"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-linkedin-limits.sh",
            "description": "Enforce LinkedIn daily/weekly rate limits"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-ad-budget.sh",
            "description": "Hard stop at 100% of approved ad budget"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/auto-commit-growth.sh",
            "description": "Auto-commit docs/growth/ content and metrics updates"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/compact-state.sh",
            "description": "Keep .startup/state.json small by archiving old handoff keys once the inline window is exceeded"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/index-handoff.sh",
            "description": "Append/upsert written handoff into .startup/handoffs/INDEX.md so the directory stays discoverable as it grows"
          }
        ]
      },
      {
        "matcher": "ScheduleWakeup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/mark-yield.sh",
            "description": "Mark a self-expiring yield sentinel when the orchestrator schedules a wakeup, so the Stop hook recognizes the yield without depending on transcript flush timing (issue #103)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-stop.sh",
            "description": "Prevent premature session exit without solution signoff (enforced after iteration 2+)"
          }
        ]
      }
    ]
  }
}
